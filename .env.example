# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=ParkWise Command Center
APP_VERSION=1.0.0
APP_ENV=development                    # development | staging | production
DEBUG=true
SECRET_KEY=change-this-to-a-random-256-bit-secret-key

# ─── API ──────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=parkwise
POSTGRES_PASSWORD=parkwise_secret
POSTGRES_DB=parkwise_db
TEST_DATABASE_URL=postgresql+psycopg2://parkwise_test:change-me@localhost:5432/parkwise_test_db
# Constructed automatically from above — override only if needed:
# DATABASE_URL=postgresql+psycopg2://parkwise:parkwise_secret@localhost:5432/parkwise_db

# ─── Connection Pool ──────────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── ML Pipeline ──────────────────────────────────────────────────────────────
DATA_DIR=./data
MODEL_DIR=./models
DBSCAN_EPS=0.005            # degrees (~500m at equator)
DBSCAN_MIN_SAMPLES=10
EIS_NORMALIZATION=percentile # percentile | minmax
FORECAST_HORIZON_DAYS=1
LIGHTGBM_NUM_LEAVES=31
LIGHTGBM_N_ESTIMATORS=200

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json              # json | text
LOG_FILE=./logs/parkwise.log
